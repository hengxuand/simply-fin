# ===========================
# macOS
# ===========================
.DS_Store
.AppleDouble
.LSOverride

# ===========================
# JetBrains IDEs
# ===========================
.idea/

# ===========================
# VS Code
# (keep launch.json / settings.json if your team shares them;
#  uncomment the line below to exclude the whole folder instead)
# ===========================
.vscode/

# ===========================
# Environment / secrets
# ===========================
.env
.env.*
*.secret
secrets/

# ===========================
# Supabase local-dev artifacts
# (safe to exclude – regenerated by `supabase start`)
# ===========================
supabase/.temp/
supabase/.branches/

# ===========================
# Supabase Edge Functions local dependencies
# ===========================
supabase/functions/node_modules/
supabase/functions/.env.*
node_modules/

# ===========================
# Flutter / Dart
# (detailed rules live in simply_fin_flutter/.gitignore)
# ===========================
simply_fin_flutter/.dart_tool/
simply_fin_flutter/.pub-cache/
simply_fin_flutter/.pub/
simply_fin_flutter/build/
simply_fin_flutter/coverage/
simply_fin_flutter/.flutter-plugins
simply_fin_flutter/.flutter-plugins-dependencies
